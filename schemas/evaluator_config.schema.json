{
  "$defs": {
    "Engine": {
      "description": "Agentic coding engine that produced an artifact.",
      "enum": [
        "claude-code",
        "codex",
        "gemini"
      ],
      "title": "Engine",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "An entry in ``config/evaluators.yaml``.",
  "properties": {
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Description"
    },
    "enabled": {
      "default": true,
      "title": "Enabled",
      "type": "boolean"
    },
    "engine": {
      "$ref": "#/$defs/Engine"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "mcp_servers": {
      "description": "Manifest ids this evaluator's cells are configured with (#525).",
      "items": {
        "type": "string"
      },
      "title": "Mcp Servers",
      "type": "array"
    },
    "model": {
      "anyOf": [
        {
          "pattern": "^[A-Za-z0-9._:-]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model"
    },
    "prompt": {
      "title": "Prompt",
      "type": "string"
    }
  },
  "required": [
    "id",
    "engine",
    "prompt"
  ],
  "title": "EvaluatorConfig",
  "type": "object"
}
