{
  "$defs": {
    "EventKind": {
      "enum": [
        "motion",
        "petition",
        "appeal",
        "order"
      ],
      "title": "EventKind",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "``event.yaml`` \u2014 one thing the system predicts about a case.",
  "properties": {
    "case_id": {
      "title": "Case Id",
      "type": "string"
    },
    "decision_target": {
      "default": "disposition",
      "title": "Decision Target",
      "type": "string"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Description"
    },
    "docket_entry_id": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Docket Entry Id"
    },
    "event_id": {
      "title": "Event Id",
      "type": "string"
    },
    "kind": {
      "$ref": "#/$defs/EventKind"
    },
    "opened_at": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Opened At"
    },
    "resolved": {
      "default": false,
      "title": "Resolved",
      "type": "boolean"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "title": {
      "title": "Title",
      "type": "string"
    }
  },
  "required": [
    "event_id",
    "case_id",
    "kind",
    "title"
  ],
  "title": "PredictableEvent",
  "type": "object"
}
