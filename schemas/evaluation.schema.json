{
  "$defs": {
    "Engine": {
      "description": "Agentic coding engine that produced an artifact.",
      "enum": [
        "claude-code",
        "codex",
        "gemini"
      ],
      "title": "Engine",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "``evaluation.json`` \u2014 one evaluator scoring one predictor's prediction.",
  "properties": {
    "brier_score": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Brier Score"
    },
    "case_id": {
      "title": "Case Id",
      "type": "string"
    },
    "correct": {
      "description": "1 if disposition matched outcome",
      "maximum": 1,
      "minimum": 0,
      "title": "Correct",
      "type": "integer"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "engine": {
      "$ref": "#/$defs/Engine"
    },
    "evaluator_id": {
      "title": "Evaluator Id",
      "type": "string"
    },
    "event_id": {
      "title": "Event Id",
      "type": "string"
    },
    "leakage_suspected": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Evaluator's judgment that the prediction shows signs of using post-decision information about this case \u2014 its outcome, the disposing order, or facts knowable only after the decision. Advisory: it segments scores, never changes them. Null when not assessed (offline evaluators and records written before the field existed)",
      "title": "Leakage Suspected"
    },
    "model": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Model that produced this evaluation (e.g. claude-fable-5); null only for offline outputs that called no model (and records written before the field existed)",
      "title": "Model"
    },
    "notes_doc": {
      "default": "evaluation.md",
      "title": "Notes Doc",
      "type": "string"
    },
    "predictor_id": {
      "title": "Predictor Id",
      "type": "string"
    },
    "reasoning_quality": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reasoning Quality"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "vote_accuracy": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Vote Accuracy"
    }
  },
  "required": [
    "case_id",
    "event_id",
    "predictor_id",
    "evaluator_id",
    "engine",
    "run_id",
    "created_at",
    "correct"
  ],
  "title": "Evaluation",
  "type": "object"
}
